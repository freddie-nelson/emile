    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "0.4.12",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "15.9.0",
    "prettier": "^3.3.3",
    "tailwindcss": "^4.3.2",
